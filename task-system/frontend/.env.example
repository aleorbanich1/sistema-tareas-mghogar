# URL base de la API. Dentro del APK NO uses localhost (apunta al celular).
# Dev local en PC:
VITE_API_URL=http://localhost:3000/api

# Para el APK / producción, poné aquí la URL pública accesible desde el celular.
# Ejemplos:
#   Red local (mismo WiFi):  http://192.168.1.45:3000/api
#   Supabase (luego):        https://TU-PROYECTO.supabase.co/rest/v1

# Clave PÚBLICA VAPID para Web Push (npx web-push generate-vapid-keys).
# La privada va SOLO en los secrets de la Edge Function de Supabase.
VITE_VAPID_PUBLIC_KEY=
